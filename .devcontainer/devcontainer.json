{
  "name": "ILERNA - Programación IA - PAC DES",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "redhat.vscode-yaml",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "cweijan.vscode-database-client2",
        "humao.rest-client",
        "usernamehw.errorlens",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.askForKernelRestart": false,
        "python.analysis.typeCheckingMode": "basic",
        "files.autoSave": "afterDelay"
      }
    }
  },
  "remoteEnv": {
    "MQTT_HOST": "mosquitto",
    "MQTT_PORT": "1883",
    "MQTT_TOPIC": "sensors/telemetry",
    "KAFKA_BROKER": "redpanda:29092",
    "KAFKA_BOOTSTRAP": "redpanda:29092",
    "KAFKA_TOPIC": "sensors_raw",
    "INFLUX_URL": "http://influxdb:8086",
    "INFLUX_TOKEN": "supersecrettoken",
    "INFLUX_ORG": "ilerna",
    "INFLUX_BUCKET": "sensores",
    "MINIO_ENDPOINT": "minio:9000",
    "MINIO_ACCESS": "admin",
    "MINIO_SECRET": "adminpassword",
    "MINIO_BUCKET": "datalake",
    "FASTAPI_URL": "http://localhost:8000",
    "ALERT_THRESHOLD": "80.0"
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r config/requirements.txt && chmod +x .devcontainer/start.sh",
  "postStartCommand": "bash .devcontainer/start.sh",
  "autoForwardPorts": false,
  "forwardPorts": [
    11883,
    19092,
    18080,
    18081,
    18086,
    19000,
    19001,
    18000,
    18501,
    13000,
    18888
  ],
  "portsAttributes": {
    "18501": {
      "label": "Streamlit (UI App)",
      "onAutoForward": "notify"
    },
    "18000": {
      "label": "FastAPI (Backend API)",
      "onAutoForward": "notify"
    },
    "13000": {
      "label": "Grafana (Dashboards)",
      "onAutoForward": "notify"
    },
    "18888": {
      "label": "Jupyter Notebook",
      "onAutoForward": "notify"
    },
    "18081": {
      "label": "Flink UI (Jobs Control)",
      "onAutoForward": "silent"
    },
    "18080": {
      "label": "Redpanda Console (Topics UI)",
      "onAutoForward": "silent"
    },
    "19001": {
      "label": "MinIO Console (Data Lake UI)",
      "onAutoForward": "silent"
    },
    "18086": {
      "label": "InfluxDB UI",
      "onAutoForward": "silent"
    },
    "11883": {
      "label": "MQTT Broker",
      "onAutoForward": "ignore"
    },
    "19092": {
      "label": "Redpanda (Kafka API)",
      "onAutoForward": "ignore"
    },
    "19000": {
      "label": "MinIO (S3 API)",
      "onAutoForward": "ignore"
    }
  }
}