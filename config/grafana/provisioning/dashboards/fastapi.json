{
  "uid": "ilerna-fastapi",
  "title": "ILERNA Smart-Industry — Estado en Tiempo Real (FastAPI)",
  "tags": ["fastapi", "iot", "temperatura", "alertas"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Máquinas monitorizadas",
      "description": "Dispositivos con datos activos en FastAPI",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["count"]},
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "unit": "short",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/machines/status",
          "url_options": {"method": "GET"},
          "root_selector": "machines",
          "columns": [
            {"selector": "device_id", "text": "Máquina", "type": "string"}
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Alertas activas (última hora)",
      "description": "Ventanas Flink con avg_temp_c > 80 °C",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["count"]},
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/alerts?range_minutes=60",
          "url_options": {"method": "GET"},
          "root_selector": "alerts",
          "columns": [
            {"selector": "device_id", "text": "Máquina", "type": "string"}
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Temperatura máxima actual",
      "description": "Mayor avg_temp_c entre las 5 máquinas",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["max"]},
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 80}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/machines/status",
          "url_options": {"method": "GET"},
          "root_selector": "machines",
          "columns": [
            {"selector": "avg_temp_c", "text": "Temp °C", "type": "number"}
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Temperatura por máquina (°C)",
      "description": "Umbral de alerta: 80 °C (rojo). Actualiza cada 10s.",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 120,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 80}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "transformations": [
        {
          "id": "rowsToFields",
          "options": {
            "nameField": "Máquina",
            "valueField": "Temp °C"
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/machines/status",
          "url_options": {"method": "GET"},
          "root_selector": "machines",
          "columns": [
            {"selector": "device_id", "text": "Máquina", "type": "string"},
            {"selector": "avg_temp_c", "text": "Temp °C", "type": "number"}
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Estado detallado por máquina",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "footer": {"show": false},
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Alerta"},
            "properties": [
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true":  {"text": "🔴 ALERTA", "color": "red",   "index": 0},
                      "false": {"text": "✅ OK",     "color": "green", "index": 1}
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Temp °C"},
            "properties": [
              {"id": "unit", "value": "celsius"},
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 60},
                    {"color": "red", "value": 80}
                  ]
                }
              },
              {"id": "color", "value": {"mode": "thresholds"}}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/machines/status",
          "url_options": {"method": "GET"},
          "root_selector": "machines",
          "columns": [
            {"selector": "device_id",  "text": "Máquina",       "type": "string"},
            {"selector": "avg_temp_c", "text": "Temp °C",        "type": "number"},
            {"selector": "alert",      "text": "Alerta",         "type": "string"},
            {"selector": "ts",         "text": "Última lectura", "type": "string"}
          ],
          "parser": "backend"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Historial de alertas (última hora)",
      "description": "Ventanas Tumble 1min donde avg_temp_c superó 80 °C",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 7},
      "datasource": {"type": "yesoreyeram-infinity-datasource", "uid": "infinity"},
      "options": {
        "footer": {"show": false},
        "showHeader": true,
        "sortBy": [{"displayName": "Timestamp", "desc": true}]
      },
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Temp °C"},
            "properties": [
              {"id": "unit", "value": "celsius"},
              {"id": "custom.displayMode", "value": "color-background"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "orange", "value": null},
                    {"color": "red", "value": 90}
                  ]
                }
              },
              {"id": "color", "value": {"mode": "thresholds"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Máquina"},
            "properties": [
              {"id": "custom.width", "value": 160}
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://workspace:8000/alerts?range_minutes=60",
          "url_options": {"method": "GET"},
          "root_selector": "alerts",
          "columns": [
            {"selector": "ts",         "text": "Timestamp", "type": "string"},
            {"selector": "device_id",  "text": "Máquina",   "type": "string"},
            {"selector": "avg_temp_c", "text": "Temp °C",   "type": "number"}
          ],
          "parser": "backend"
        }
      ]
    }
  ]
}
